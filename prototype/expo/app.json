{
  "expo": {
    "name": "Impulse",
    "slug": "impulse-blueprint",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "impulse-blueprint",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D0F1A",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.impulse.blueprint",
      "buildNumber": "2",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Impulse listens to your answers so it can understand you.",
        "NSSpeechRecognitionUsageDescription": "Impulse transcribes your voice to build your Human Blueprint.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.impulse.blueprint",
      "adaptiveIcon": {
        "backgroundColor": "#0D0F1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0F1A",
          "image": "./assets/icon.png",
          "imageWidth": 120
        }
      ],
      "expo-secure-store",
      "expo-audio",
      "expo-asset",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Impulse listens to your answers so it can understand you.",
          "speechRecognitionPermission": "Impulse transcribes your voice to build your Human Blueprint."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Impulse uses your location to provide location check-ins you turn on yourself — occasional notifications about where you appear to be, even while the app is closed.",
          "locationAlwaysPermission": "Impulse uses your location to provide location check-ins you turn on yourself, even while the app is closed.",
          "locationWhenInUsePermission": "Impulse uses your location to provide location check-ins you turn on yourself.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-task-manager",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/64226c67-1f05-4b18-82d7-6081195a6e7a"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "64226c67-1f05-4b18-82d7-6081195a6e7a"
      }
    }
  }
}
